# Frontend environment variables. Copy to .env.local and fill in.
# .env.local is gitignored; production values live on Railway.
#
# NEXT_PUBLIC_* are baked into the client bundle at build time (declare a matching
# ARG in the Dockerfile for Railway builds). Everything else is server-only and
# is read at runtime inside /pages/api routes; it never reaches the browser.

# --- Self-hosted source pipeline (Option B) -------------------------------
# Point the frontend at the source-service for the direct HLS player. Unset in
# production so Railway stays on the embed fallback. See docs/STREAMING-ROADMAP.md.
NEXT_PUBLIC_SOURCE_SERVICE_URL=http://localhost:8088

# --- AniList OAuth (authorization code grant) -----------------------------
# Client id is public (bundled); the secret is server-only (used by
# /api/auth/anilist to exchange the code for a token). Redirect on the AniList
# app must be <origin>/auth/callback.
NEXT_PUBLIC_ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# --- AI watch companion (docs/STREAMING-ROADMAP.md §11) -------------------
# Server-only. OpenAI-compatible endpoint, so the default free Gemini today and
# a local Ollama later are the same code with a different base URL. Leave the key
# empty and the companion panel renders a setup note instead of failing.
# Free Gemini key: https://aistudio.google.com/apikey
COMPANION_API_KEY=
COMPANION_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# gemini-2.0-flash free tier is now zeroed for new keys; use 2.5-flash.
COMPANION_MODEL=gemini-2.5-flash
# Groq alternative (faster):
#   COMPANION_API_BASE=https://api.groq.com/openai/v1
#   COMPANION_MODEL=llama-3.3-70b-versatile
