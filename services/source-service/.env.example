# Copy to .env and adjust. All optional — sane defaults are built in.

PORT=8080

# Comma-separated provider priority (resolver tries them in this order).
PROVIDERS=allanime,animepahe

# FlareSolverr endpoint (the docker-compose service). Used to pass Cloudflare.
FLARESOLVERR_URL=http://flaresolverr:8191/v1

# Optional residential/ISP proxy passed to FlareSolverr for challenged hosts.
# Leave blank until the PoC proves the VPS IP alone gets blocked.
PROXY_URL=

# Resolved-source cache TTL (ms) and subtitle cache TTL (ms).
SOURCE_TTL_MS=900000
SUBTITLE_TTL_MS=86400000

# Circuit breaker: failures within window before a provider is skipped, + cooldown.
BREAKER_THRESHOLD=4
BREAKER_COOLDOWN_MS=120000

# Allowed CORS origins for the frontend (comma-separated, or * for any).
CORS_ORIGINS=*

# OpenSubtitles API key (Phase 3 — Indonesian/English subtitles). Optional for now.
OPENSUBTITLES_API_KEY=
